    },
    {
      "GUID": "6d9f9b26-b05f-4227-92ee-e223a628d0d3",
      "glossaryId": "40011719-5198-41cd-a043-fb7d8da9bdf0",
      "name": "Street Name",
      "properties": {
        "17f60aaa-d39c-4fd5-9a7f-c50c2fdcce83": "a1111111-aaaa-4aaa-8aaa-aaaaaaaa0005",
        "5dad6df2-40ba-4ba9-98d0-8c5e732d4d7c": "Street Name",
        "faa8f3a2-c098-422e-b197-89e62099d751": "The official designation of a public way intended for vehicular and pedestrian traffic, forming part of an address for location identification and mail delivery.",
        "3cb23801-1bda-48e3-8c81-c03b5bf953e2": "Location",
        "265be069-8378-438a-876c-079cf8f5b015": "Street;Road Name",
