    {
      "GUID": "50f654c2-67a3-409d-9126-2a05b9c61f15",
      "glossaryId": "40011719-5198-41cd-a043-fb7d8da9bdf0",
      "name": "Postal Code",
      "properties": {
        "17f60aaa-d39c-4fd5-9a7f-c50c2fdcce83": "a1111111-aaaa-4aaa-8aaa-aaaaaaaa0007",
        "5dad6df2-40ba-4ba9-98d0-8c5e732d4d7c": "Postal Code",
        "faa8f3a2-c098-422e-b197-89e62099d751": "A standardized alphanumeric or numeric code assigned by a postal service to a specific geographic region or address. It facilitates the efficient sorting, routing, and delivery of mail and packages by uniquely identifying delivery areas.",
        "3cb23801-1bda-48e3-8c81-c03b5bf953e2": "Location",
        "265be069-8378-438a-876c-079cf8f5b015": "ZIP Code;Postcode",
