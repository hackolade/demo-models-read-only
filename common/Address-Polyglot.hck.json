  "businessGlossaryTerms": [
    {
      "GUID": "ba4e7703-79aa-48d5-941a-1bcf5e5382ce",
      "glossaryId": "40011719-5198-41cd-a043-fb7d8da9bdf0",
      "name": "Address",
      "properties": {
        "17f60aaa-d39c-4fd5-9a7f-c50c2fdcce83": "a1111111-aaaa-4aaa-8aaa-aaaaaaaa0004",
        "5dad6df2-40ba-4ba9-98d0-8c5e732d4d7c": "Address",
        "faa8f3a2-c098-422e-b197-89e62099d751": "A structured representation of a physical location, composed of distinct elements such as street name, house number, city, postal code, and country, utilized for various business functions including, but not limited to, the delivery of goods and services, the origination of financial transactions for billing and invoicing, and the establishment of contact points for correspondence or official communication.",
        "3cb23801-1bda-48e3-8c81-c03b5bf953e2": "Location",
        "265be069-8378-438a-876c-079cf8f5b015": "Postal Address;Location",
        "277de272-a284-49a9-8880-0ec96796230c": "Validated"
      },
      "refIds": [
        "50ec3adc-dd4a-4ddf-bab7-572b8e9b8bf7"
      ],
      "updatedAt": "2026-03-31T06:56:57.080Z"
    },
    {
      "GUID": "35d4b7f7-0934-45d1-8c33-4e7ed4dec3c8",
      "glossaryId": "40011719-5198-41cd-a043-fb7d8da9bdf0",
      "name": "Identifier",
      "properties": {
        "17f60aaa-d39c-4fd5-9a7f-c50c2fdcce83": "a1111111-aaaa-4aaa-8aaa-aaaaaaaa0011",
        "5dad6df2-40ba-4ba9-98d0-8c5e732d4d7c": "Identifier",
        "faa8f3a2-c098-422e-b197-89e62099d751": "A unique and unambiguous value assigned to a specific business entity or record, ensuring its distinctness within a given system or dataset. This identifier serves as a reference point for data retrieval, linkage, and management, maintaining data integrity and facilitating accurate reporting and analysis.",
        "3cb23801-1bda-48e3-8c81-c03b5bf953e2": "System",
        "265be069-8378-438a-876c-079cf8f5b015": "ID;Identifier Value",
