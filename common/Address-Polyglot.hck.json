    },
    {
      "GUID": "95bf7217-fe25-4a18-b6d8-85e666b86c51",
      "glossaryId": "40011719-5198-41cd-a043-fb7d8da9bdf0",
      "name": "City",
      "properties": {
        "17f60aaa-d39c-4fd5-9a7f-c50c2fdcce83": "a1111111-aaaa-4aaa-8aaa-aaaaaaaa0006",
        "5dad6df2-40ba-4ba9-98d0-8c5e732d4d7c": "City",
        "faa8f3a2-c098-422e-b197-89e62099d751": "The specific municipality or administrative division within a larger geographical region, forming a core component of a complete postal address. This term denotes the urban settlement where a specific location is situated, and it is critical for accurate mail delivery, geographical identification, and data segmentation.",
        "3cb23801-1bda-48e3-8c81-c03b5bf953e2": "Location",
        "265be069-8378-438a-876c-079cf8f5b015": "Town;Municipality",
