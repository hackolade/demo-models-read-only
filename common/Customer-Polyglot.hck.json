  "businessGlossaryTerms": [
    {
      "GUID": "f18ae58f-5e1e-425b-a027-7109a2571f80",
      "glossaryId": "a0f9430a-73ca-4114-a139-1befb9bb8dfa",
      "name": "Customer",
      "properties": {
        "ce24f325-07bd-42da-ac55-591fc34927ae": "a1111111-aaaa-4aaa-8aaa-aaaaaaaa0001",
        "8b2aa3ec-4606-4473-af11-3c4e931c7dcf": "Customer",
        "f9858762-0d5a-4c87-a96e-7b39f7fe5204": "An individual, household, or organization that engages with the company for the purpose of purchasing products, utilizing services, or establishing a mutually beneficial relationship. This interaction may involve placing orders, receiving deliverables, or engaging in ongoing service agreements, signifying a formal or informal commitment to the business's offerings.",
        "fa198b6b-d0b3-44d1-966e-a3728c6fe5be": "Party",
        "8890c553-628b-4bff-8958-d97c2901cb9c": "Client;Buyer",
        "01891e24-ba26-495d-b7b0-3cf5563b66d7": "Validated"
      },
      "refIds": [
        "5cc94e26-8eb9-4b1c-a78d-a870d9f640db"
      ],
