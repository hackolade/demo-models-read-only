    },
    {
      "GUID": "f8d40c97-1496-44a8-aa71-e5d901c4c50e",
      "glossaryId": "a0f9430a-73ca-4114-a139-1befb9bb8dfa",
      "name": "Email Address",
      "properties": {
        "ce24f325-07bd-42da-ac55-591fc34927ae": "a1111111-aaaa-4aaa-8aaa-aaaaaaaa0009",
        "8b2aa3ec-4606-4473-af11-3c4e931c7dcf": "Email Address",
        "f9858762-0d5a-4c87-a96e-7b39f7fe5204": "A unique identifier assigned to an individual or entity, facilitating the transmission and reception of digital messages through a networked communication system. It comprises a local-part and a domain-part, separated by the '@' symbol, adhering to standardized formats for interoperability across various email service providers and platforms.",
        "fa198b6b-d0b3-44d1-966e-a3728c6fe5be": "Contact",
        "8890c553-628b-4bff-8958-d97c2901cb9c": "Email;Mail Address",
        "01891e24-ba26-495d-b7b0-3cf5563b66d7": "Validated"
      },
      "refIds": [
        "18d05aa0-70b0-4f8e-9736-ffbc7104f778"
      ],
      "updatedAt": "2026-03-31T06:56:57.080Z"
    },
    {
      "GUID": "74c65bc9-2d22-48f3-8ca4-3087ba30655f",
      "glossaryId": "a0f9430a-73ca-4114-a139-1befb9bb8dfa",
      "name": "Address",
      "properties": {
        "ce24f325-07bd-42da-ac55-591fc34927ae": "a1111111-aaaa-4aaa-8aaa-aaaaaaaa0004",
        "8b2aa3ec-4606-4473-af11-3c4e931c7dcf": "Address",
        "f9858762-0d5a-4c87-a96e-7b39f7fe5204": "A structured representation of a physical location, composed of distinct elements such as street name, house number, city, postal code, and country, utilized for various business functions including, but not limited to, the delivery of goods and services, the origination of financial transactions for billing and invoicing, and the establishment of contact points for correspondence or official communication.",
        "fa198b6b-d0b3-44d1-966e-a3728c6fe5be": "Location",
        "8890c553-628b-4bff-8958-d97c2901cb9c": "Postal Address;Location",
        "01891e24-ba26-495d-b7b0-3cf5563b66d7": "Validated"
      },
      "refIds": [
        "a569060a-b3b2-4f73-95c7-7c2e2145c273"
      ],
      "updatedAt": "2026-05-20T06:52:44.312Z"
    },
    {
      "GUID": "929add6e-ec78-4fc2-a0db-25775b737a41",
      "glossaryId": "4f9c11b4-a5e5-42b7-8fa5-62a141a2693a",
      "name": "Ship-to Address",
      "properties": {
        "4b44b89e-933f-49c3-ae51-3c39236a33dc": "b2222222-bbbb-4bbb-8bbb-bbbbbbbb0012",
        "4738633b-a25a-484c-b5e9-fd77af6094fc": "Ship-to Address",
        "24b15b0c-0e14-40db-87cc-46274c8262c6": "The designated physical location to which goods, services, or shipments are dispatched and received by the customer or recipient. This includes all necessary components for accurate delivery, such as street name, house or building number, city, postal code, and country.",
        "9547393f-a961-4c9c-b236-5239258451e9": "Fulfillment",
        "e9923906-d3bf-45a4-a572-3d1a8858f151": "Shipping Address;Destination",
        "3835ad08-8721-4b19-b3ac-2cfe74085058": "Validated"
      },
      "refIds": [
