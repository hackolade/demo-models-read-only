    {
      "GUID": "8e0c5872-191a-4621-b82e-bd29b419ba1c",
      "glossaryId": "a0f9430a-73ca-4114-a139-1befb9bb8dfa",
      "name": "Phone Number",
      "properties": {
        "ce24f325-07bd-42da-ac55-591fc34927ae": "a1111111-aaaa-4aaa-8aaa-aaaaaaaa0010",
        "8b2aa3ec-4606-4473-af11-3c4e931c7dcf": "Phone Number",
